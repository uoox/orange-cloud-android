    "语言默认跟随系统。更改语言后需重新打开 App 生效。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Language follows the system by default. Reopen the app for language changes to take effect."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "言語はデフォルトでシステムに従います。変更後はアプリを開き直すと反映されます。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "語言預設跟隨系統。變更語言後需重新開啟 App 才會生效。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "語言預設跟隨系統。更改語言後需重新開啟 App 方會生效。"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "El idioma sigue al del sistema por defecto. Reabre la app para que el cambio surta efecto."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "언어는 기본적으로 시스템을 따릅니다. 언어 변경 후에는 앱을 다시 열어야 적용됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O idioma segue o do sistema por padrão. Reabra o app para que a mudança tenha efeito."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O idioma segue o do sistema por predefinição. Reabra a app para que a alteração tenha efeito."
          }
        }
      }
    },
