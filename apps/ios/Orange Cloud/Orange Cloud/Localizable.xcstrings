    "规则按从上到下的顺序执行，左滑可删除。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rules run top to bottom. Swipe left to delete."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルールは上から順に実行されます。左にスワイプで削除できます。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "規則按從上到下的順序執行，左滑可刪除。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "規則按從上到下的順序執行，左滑可刪除。"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Las reglas se ejecutan de arriba abajo. Desliza a la izquierda para eliminar."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "규칙은 위에서 아래로 실행됩니다. 왼쪽으로 밀어 삭제하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As regras são executadas de cima para baixo. Deslize para a esquerda para excluir."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "As regras são executadas de cima para baixo. Deslize para a esquerda para eliminar."
          }
        }
      }
    },
    "规则用 Cloudflare Rules 表达式匹配请求，满足时运行此 Snippet。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rules match requests with Cloudflare Rules expressions; this snippet runs on a match."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルールは Cloudflare Rules 式でリクエストを照合し、一致するとこのスニペットが実行されます。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "規則以 Cloudflare Rules 運算式比對請求，相符時執行此 Snippet。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "規則以 Cloudflare Rules 運算式比對請求，符合時執行此 Snippet。"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Las reglas coinciden con las solicitudes mediante expresiones de Cloudflare Rules; este snippet se ejecuta cuando hay coincidencia."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "규칙은 Cloudflare Rules 표현식으로 요청을 일치시키며, 일치하면 이 Snippet이 실행됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As regras correspondem às solicitações com expressões do Cloudflare Rules; este snippet é executado quando há correspondência."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "As regras correspondem aos pedidos com expressões do Cloudflare Rules; este snippet é executado quando há correspondência."
          }
        }
      }
    },
